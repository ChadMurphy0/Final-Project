from Linear_Programming_Main_Code import *

# Run the profit maximization problem

# Economics Problem Example (This isn't actually a problem I've had on a test, but certainly something similar): 
# A producer can produce chairs and tables. They are looking to make the maximum amount of profit for their business.
# However, they are only able to produce a maximum of 200 chairs, 300 tables, and 400 chairs and tables.
# The profit funciton for the allocation is pi(x1, x2) = x_1 + 6x_2. What is the maximum profit and best allocation of chairs and tables?

if __name__ == "__main__":
    # Maximize the user's input
    c = [1, 6] # In this case, it will maximize x_1 and 6x_2
    # This entry are the constraints
    A = [[1, 0], # x1 <= 200, less than 200 chairs
        [0, 1], # x2 <= 300, less than 300 tables
        [1, 1],] # x1 + x2 <= 400, less than 400 of both
    b = [200, 300, 400] # Maximum available resources

    # Run the simplex algorithm for our functions
    optimal_allocation, maximum_profix = Simplex(c, A, b)

    print(f"The maximum profit for this problem is: {maximum_profix} (according to our created method)")
    print(f"The x1 goods to produce are: {optimal_allocation[0]} (according to our created method)")
    print(f"The x2 goods to produce are: {optimal_allocation[1]} (according to our created method)")


# Compare to Python linear programming method:
from scipy.optimize import linprog

# Same inputs as above, just negative c values since this funcion only minimizes
c = [-1, -6]
A = [[1, 0],
    [0, 1], 
    [1, 1]] 
b = [200, 300, 400]

result = linprog(c, A, b)

print(f"The maximum profit for this problem is: {-result.fun} (according to ScyPi's method)") # We need to flip the negative sign again, since this is minimizing
print(f"The x1 goods to produce are: {result.x[0]} (according to ScyPi's method)") # This is the optimal allocation for the first good
print(f"The x2 goods to produce are: {result.x[1]} (according to ScyPi's method)") # This is the optimal allocation for the second good

# These two values match! (Our calculation using our own Simplex method, and SciPy's calculation)



